#!/usr/bin/env bash
# Mock for Jivaro parasitic reduction (``jivaro -xml <file>``).
set -u
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_common.sh
. "${HERE}/_common.sh"

out_dir="$(_mock_out_dir)"
mkdir -p "${out_dir}"
artifact="${out_dir}/mock.jivaro.spef"

echo "// MOCK jivaro invoked with: $*"

if _mock_should_fail "$@"; then
    echo "// MOCK jivaro: simulated failure" >&2
    exit 3
fi

cat > "${artifact}" <<'EOF'
// MOCK reduced SPEF output placeholder
*SPEF "IEEE 1481-1998"
*DESIGN "mock_reduced"
EOF
echo "// MOCK jivaro: wrote ${artifact}"
exit 0
